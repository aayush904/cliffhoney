{% doc %}
  @prompt
    i a want a section with that will have image with contact form. It should have an option to add heading, description, and social icon, there is already options to enter the social link in the theme setting just import the social media snippets if social media is enabled. make the heading tag h1.  make the form button full width. instead of chooseing diffrent color make a option to choose the color schema  and use the color variable as its in theme code.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
    .ai-contact-section-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(24px, 2.61vw, 5rem);
      align-items: start;
      padding: 0 20px;
    }

    {% comment %} .contact-column{
      width: calc(50% - clamp(24px,2.61vw,5rem)/2);
    } {% endcomment %}

    .ai-contact-section-{{ ai_gen_id }}.color-scheme-1 {
      background-color: rgb(var(--color-background));
      color: rgb(var(--color-foreground));
    }

    .ai-contact-section-{{ ai_gen_id }}.color-scheme-2 {
      background-color: rgb(var(--color-background));
      color: rgb(var(--color-foreground));
    }

  .ai-contact-section-{{ ai_gen_id }} {
  justify-content: space-between;
  position:relative;
  }
    .ai-contact-image-wrapper-{{ ai_gen_id }} {
      position: sticky;
      top:12rem;
      border-radius: {{ block.settings.image_border_radius }}px;
      overflow: hidden;
      max-width: 100%;
      height:100%;

    }

    .ai-contact-image-{{ ai_gen_id }} {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .ai-contact-image-placeholder-{{ ai_gen_id }} {
      width: 100%;
      height: 100%;
      background-color: rgba(var(--color-foreground), 0.04);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ai-contact-image-placeholder-{{ ai_gen_id }} svg {
      width: 100%;
      height: 100%;
      max-width: 200px;
      max-height: 200px;
      color: rgba(var(--color-foreground), 0.3);
    }

    .ai-contact-content-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-contact-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size }}px;
      color: rgb(var(--color-foreground));
      margin: 0 0 5rem 0;
      font-weight: 700;
      p{
      margin:0;
      }
    }

    .ai-contact-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size }}px;
      color: rgb(var(--color-foreground));
      margin-bottom: 32px;
      line-height: 1.6;
    }

    .ai-contact-form-{{ ai_gen_id }} {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 32px;
    }

    .ai-contact-form-row-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .ai-contact-input-{{ ai_gen_id }},
    .ai-contact-textarea-{{ ai_gen_id }} {
      padding: 12px 16px;
      border: 1px solid rgba(var(--color-foreground), 0.2);
      border-radius: {{ block.settings.input_border_radius }}px;
      font-size: 14px;
      background-color: rgb(var(--color-background));
      color: rgb(var(--color-foreground));
    }

    .ai-contact-input-{{ ai_gen_id }}:focus,
    .ai-contact-textarea-{{ ai_gen_id }}:focus {
      outline: none;
      border-color: rgb(var(--color-button));
    }

    .ai-contact-textarea-{{ ai_gen_id }} {
      min-height: 120px;
      resize: vertical;
    }

    .ai-contact-button-{{ ai_gen_id }} {
      padding: 14px 28px;
      background-color: rgb(var(--color-button));
      color: rgb(var(--color-button-text));
      border: none;
      border-radius: {{ block.settings.button_border_radius }}px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: background-color 0.3s ease;
      width: 100%;
    }

    .ai-contact-button-{{ ai_gen_id }}:hover {
      background-color: rgba(var(--color-button), 0.8);
    }
    .ai-contacts-{{ ai_gen_id }} {
      display:flex;
      gap: 24px;
      flex-wrap:wrap;
    }

    .ai-contacts-{{ ai_gen_id }} h3{
      margin-bottom: 24px;
    }

    .ai-contacts-{{ ai_gen_id }} a{
      text-decoration: none;
      transition: all 0.3s ease;
      color:var(--color-text);

    }
    .ai-contacts-{{ ai_gen_id }} a:hover{
        font-weight:500;
        transform:scale(1.1);
    }


    .ai-contact-social-{{ ai_gen_id }} {
      display: flex;
      gap: 16px;
      align-items: center;}

    .ai-contact-social-icon-{{ ai_gen_id }} {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: {{ block.settings.social_icon_size }}px;
      height: {{ block.settings.social_icon_size }}px;
      background-color: rgba(var(--color-foreground), 0.1);
      color: rgb(var(--color-foreground));
      border-radius: 50%;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .ai-contact-social-icon-{{ ai_gen_id }}:hover {
      background-color: rgb(var(--color-button));
      color: rgb(var(--color-button-text));
      transform: translateY(-2px);
    }

    .ai-contact-social-icon-{{ ai_gen_id }} svg {
      width: calc({{ block.settings.social_icon_size }}px * 0.5);
      height: calc({{ block.settings.social_icon_size }}px * 0.5);
    }

    .ai-contact-success-{{ ai_gen_id }} {
      color: #008060;
      margin-top: 16px;font-size: 14px;
    }

    .ai-contact-error-{{ ai_gen_id }} {
      color: #D82C0D;
      margin-top: 8px;
      font-size: 14px;
    }

    @media screen and (max-width: 1024px) {
      .ai-contact-form-row-{{ ai_gen_id }} {
        grid-template-columns: 1fr;
      }
    }

    @media screen and (max-width: 768px) {
      .ai-contact-section-{{ ai_gen_id }} {
        grid-template-columns: 1fr;
        gap: 32px;
        padding: 0 20px;
      }

        .ai-contact-image-wrapper-{{ ai_gen_id }} {
          position:static;
        }



      .ai-contact-image-wrapper-{{ ai_gen_id }} {
        height: 300px;
      }

      .ai-contact-heading-{{ ai_gen_id }} {
        font-size: calc({{ block.settings.heading_size }}px * 0.8);
      }

      .ai-contact-description-{{ ai_gen_id }} {
        font-size: calc({{ block.settings.description_size }}px * 0.9);
      }
    }
{% endstyle %}

<div
  class="page-width ai-contact-section-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}"
  {{ block.shopify_attributes }}
>
  <div class="contact-column ai-contact-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.media_type == 'custom_code' and block.settings.custom_code != blank %}
      <div class="ai-contact-image-{{ ai_gen_id }}">
        {{ block.settings.custom_code }}
      </div>
    {% else %}
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 800 }}"
          alt="{{ block.settings.image.alt | escape }}"
          class="ai-contact-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-contact-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    {% endif %}
  </div>

  <div class="contact-column ai-contact-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h1 class="ai-contact-heading-{{ ai_gen_id }}">
        {{ block.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}
      </h1>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-contact-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    {% form 'contact' %}
      <div class="ai-contact-form-{{ ai_gen_id }}">
        <div class="ai-contact-form-row-{{ ai_gen_id }}">
          <input
            type="text"
            name="contact[first_name]"
            class="ai-contact-input-{{ ai_gen_id }}"
            placeholder="First Name"
            value="{{ form.first_name }}"
            required
          >
          <input
            type="text"
            name="contact[last_name]"
            class="ai-contact-input-{{ ai_gen_id }}"
            placeholder="Last Name"
            value="{{ form.last_name }}"
            required
          >
        </div>
        <input
          type="email"
          name="contact[email]"
          class="ai-contact-input-{{ ai_gen_id }}"
          placeholder="Email Address"
          value="{{ form.email }}"
          autocomplete="email"
          {% if form.errors %}
            aria-invalid="true"
            aria-describedby="ai-contact-error-{{ ai_gen_id }}"
          {% endif %}
          {% if form.posted_successfully? %}
            aria-describedby="ai-contact-success-{{ ai_gen_id }}"
          {% endif %}
          required
        >
        <input
          type="tel"
          name="contact[phone]"
          class="ai-contact-input-{{ ai_gen_id }}"
          placeholder="Phone Number"
          value="{{ form.phone }}"
          autocomplete="tel"
        >
        <textarea
          name="contact[body]"
          class="ai-contact-textarea-{{ ai_gen_id }}"
          placeholder="Your Message"
          required
        >{{ form.body }}</textarea>
        <button type="submit" class="ai-contact-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>

        {% if form.errors %}
          <div id="ai-contact-error-{{ ai_gen_id }}" class="ai-contact-error-{{ ai_gen_id }}">
            {{ form.errors.messages.email }}
          </div>
        {% endif %}

        {% if form.posted_successfully? %}
          <div id="ai-contact-success-{{ ai_gen_id }}" class="ai-contact-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {% endif %}
      </div>
    {% endform %}

    {% if block.settings.contact_email != blank
      or block.settings.contact_phone != blank
      or block.settings.contact_phone_2 != blank
      or block.settings.show_social_icons != blank
    %}
      <div class="ai-contacts-{{ ai_gen_id }}">
        {% if block.settings.contact_email != blank
          or block.settings.contact_phone != blank
          or block.settings.contact_phone_2 != blank
        %}
          <div>
            <h3>Contact Us</h3>

            {% if block.settings.contact_phone != blank or block.settings.contact_phone_2 != blank %}
              <div class="ai-contact-phone-{{ ai_gen_id }}">
                <a href="tel:{{ block.settings.contact_phone | remove: ' ' }}">{{ block.settings.contact_phone }}</a>
                {%- if block.settings.contact_phone != blank and block.settings.contact_phone_2 != blank -%},{% endif %}
                {% if block.settings.contact_phone_2 != blank %}
                  <a href="tel:{{ block.settings.contact_phone_2 | remove: ' ' }}">
                    {{- block.settings.contact_phone_2 -}}
                  </a>
                {% endif %}
              </div>
            {% endif %}

            {% if block.settings.contact_email != blank %}
              <div class="ai-contact-email-{{ ai_gen_id }}">
                <a href="mailto:{{ block.settings.contact_email }}">{{ block.settings.contact_email }}</a>
              </div>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.show_social_icons != blank %}
          <div>
            <h3>Follow Us On</h3>
            <div class="ai-contact-social-{{ ai_gen_id }}">
              {% if settings.social_facebook_link != blank %}
                <a
                  href="{{ settings.social_facebook_link }}"
                  class="ai-contact-social-icon-{{ ai_gen_id }}"
                  target="_blank"
                  rel="noopener"
                  aria-label="Facebook"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </a>
              {% endif %}

              {% if settings.social_instagram_link != blank %}
                <a
                  href="{{ settings.social_instagram_link }}"
                  class="ai-contact-social-icon-{{ ai_gen_id }}"
                  target="_blank"
                  rel="noopener"
                  aria-label="Instagram"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                </a>
              {% endif %}

              {% if settings.social_twitter_link != blank %}
                <a
                  href="{{ settings.social_twitter_link }}"
                  class="ai-contact-social-icon-{{ ai_gen_id }}"
                  target="_blank"
                  rel="noopener"
                  aria-label="Twitter"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                  </svg>
                </a>
              {% endif %}

              {% if settings.social_youtube_link != blank %}
                <a
                  href="{{ settings.social_youtube_link }}"
                  class="ai-contact-social-icon-{{ ai_gen_id }}"
                  target="_blank"
                  rel="noopener"
                  aria-label="YouTube"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                </a>
              {% endif %}

              {% if settings.social_tiktok_link != blank %}
                <a
                  href="{{ settings.social_tiktok_link }}"
                  class="ai-contact-social-icon-{{ ai_gen_id }}"
                  target="_blank"
                  rel="noopener"
                  aria-label="TikTok"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.171.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.021.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                  </svg>
                </a>
              {% endif %}

              {% if settings.social_pinterest_link != blank %}
                <a
                  href="{{ settings.social_pinterest_link }}"
                  class="ai-contact-social-icon-{{ ai_gen_id }}"
                  target="_blank"
                  rel="noopener"
                  aria-label="Pinterest"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.758-1.378l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.624 0 11.99-5.367 11.99-11.987C24.007 5.367 18.641.001.017.001z"/>
                  </svg>
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Contact with image",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "custom_code",
          "label": "Custom code"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Displayed when media type is set to Image"
    },
    {
      "type": "html",
      "id": "custom_code",
      "label": "Custom code",
      "info": "Add custom HTML/embed code (e.g., Google Maps). Displayed when media type is set to Custom code"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Send message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for your message! We'll get back to you soon."
    },
    {
      "type": "header",
      "content": "Contacts"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Contact phone"
    },
    {
      "type": "text",
      "id": "contact_phone_2",
      "label": "Contact phone 2"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 8
    },
