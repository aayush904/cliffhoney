{% doc %}
  @prompt
    i a want a section with that will have image/custom_code(to include a map) with contact form. It should have an option to add heading, description, 2 contact number fields, conatct mail and social icon, there is already options to enter the social link in the theme setting just import the social media snippets if social media is enabled. make the heading tag h1.  make the form button full width. instead of chooseing diffrent color make a option to choose the color schema  and use the color variable as its in theme code.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-contact-section-{{ ai_gen_id }} {
    padding: 50px 20px;
  }

  .ai-contact-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-contact-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  .ai-contact-left-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .ai-contact-heading-{{ ai_gen_id }} {
    margin: 0 0 16px;
    font-size: 2.5rem;
    line-height: 1.2;
  }

  .ai-contact-description-{{ ai_gen_id }} {
    margin: 0 0 24px;
    line-height: 1.6;
  }

  .ai-contact-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-info-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-contact-info-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-contact-info-text-{{ ai_gen_id }} {
    font-size: 1rem;
  }

  .ai-contact-media-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ settings.media_radius }}px;
    overflow: hidden;
  }

  .ai-contact-media-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-contact-media-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: rgba(var(--color-foreground), 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-contact-media-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-contact-custom-code-{{ ai_gen_id }} {
    width: 100%;
    min-height: 300px;
  }

  .ai-contact-form-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-contact-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-contact-form-field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-contact-form-label-{{ ai_gen_id }} {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .ai-contact-form-input-{{ ai_gen_id }},
  .ai-contact-form-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: {{ settings.inputs_border_thickness }}px solid rgba(var(--color-foreground), {{ settings.inputs_border_opacity | divided_by: 100.0 }});
    border-radius: {{ settings.inputs_radius }}px;
    font-size: 1rem;
    font-family: inherit;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  .ai-contact-form-textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;
  }

  .ai-contact-form-input-{{ ai_gen_id }}:focus,
  .ai-contact-form-textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid rgb(var(--color-foreground));
    outline-offset: 2px;
  }

  .ai-contact-form-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border: {{ settings.buttons_border_thickness }}px solid rgba(var(--color-button), {{ settings.buttons_border_opacity | divided_by: 100.0 }});
    border-radius: {{ settings.buttons_radius }}px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-contact-form-button-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-contact-form-success-{{ ai_gen_id }} {
    padding: 12px 16px;
    background-color: #d4edda;
    color: #155724;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  .ai-contact-form-error-{{ ai_gen_id }} {
    padding: 12px 16px;
    background-color: #f8d7da;
    color: #721c24;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  .ai-contact-social-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .ai-contact-social-{{ ai_gen_id }} ul {
    display: flex;
    gap: 12px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-contact-social-{{ ai_gen_id }} li {
    margin: 0;
  }

  .ai-contact-social-{{ ai_gen_id }} a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: rgba(var(--color-foreground), 0.1);
    color: rgb(var(--color-foreground));
    transition: all 0.3s ease;
  }

  .ai-contact-social-{{ ai_gen_id }} a:hover {
    background-color: rgba(var(--color-foreground), 0.2);
  }

  .ai-contact-social-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-contact-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-contact-heading-{{ ai_gen_id }} {
      font-size: 2rem;
    }
  }
{% endstyle %}

<div
  class="page-width ai-contact-section-{{ ai_gen_id }} color-{{ block.settings.color_scheme }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-contact-container-{{ ai_gen_id }}">
    <div class="ai-contact-grid-{{ ai_gen_id }}">
      <div class="ai-contact-left-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h1 class="ai-contact-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-contact-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
        {% endif %}

        <div class="ai-contact-info-{{ ai_gen_id }}">
          {% if block.settings.phone_1 != blank %}
            <div class="ai-contact-info-item-{{ ai_gen_id }}">
              <svg
                class="ai-contact-info-icon-{{ ai_gen_id }}"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
              <span class="ai-contact-info-text-{{ ai_gen_id }}">{{ block.settings.phone_1 }}</span>
            </div>
          {% endif %}

          {% if block.settings.phone_2 != blank %}
            <div class="ai-contact-info-item-{{ ai_gen_id }}">
              <svg
                class="ai-contact-info-icon-{{ ai_gen_id }}"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
              <span class="ai-contact-info-text-{{ ai_gen_id }}">{{ block.settings.phone_2 }}</span>
            </div>
          {% endif %}

          {% if block.settings.email != blank %}
            <div class="ai-contact-info-item-{{ ai_gen_id }}">
              <svg
                class="ai-contact-info-icon-{{ ai_gen_id }}"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              <span class="ai-contact-info-text-{{ ai_gen_id }}">{{ block.settings.email }}</span>
            </div>
          {% endif %}
        </div>

        {% if block.settings.show_social %}
          {% if settings.social_facebook_link != blank
            or settings.social_instagram_link != blank
            or settings.social_youtube_link != blank
            or settings.social_tiktok_link != blank
            or settings.social_twitter_link != blank
            or settings.social_linkedin_link != blank
            or settings.social_pinterest_link != blank
          %}
            <div class="ai-contact-social-{{ ai_gen_id }}">
              {% render 'social-icons' %}
            </div>
          {% endif %}
        {% endif %}

        {% if block.settings.media_type == 'image' %}
          <div class="ai-contact-media-{{ ai_gen_id }}">
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {% else %}
              <div class="ai-contact-media-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
        {% elsif block.settings.media_type == 'custom_code' %}
          {% if block.settings.custom_code != blank %}
            <div class="ai-contact-custom-code-{{ ai_gen_id }}">
              {{ block.settings.custom_code }}
            </div>
          {% endif %}
        {% endif %}
      </div>

      <div class="ai-contact-form-wrapper-{{ ai_gen_id }}">
        {%- form 'contact' -%}
          <div class="ai-contact-form-{{ ai_gen_id }}">
            {% if form.posted_successfully? %}
              <div class="ai-contact-form-success-{{ ai_gen_id }}">
                {{ block.settings.success_message }}
              </div>
            {% endif %}

            {% if form.errors %}
              <div class="ai-contact-form-error-{{ ai_gen_id }}">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div class="ai-contact-form-field-{{ ai_gen_id }}">
              <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-name-{{ ai_gen_id }}">
                Name <span aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="contact-name-{{ ai_gen_id }}"
                name="contact[name]"
                class="ai-contact-form-input-{{ ai_gen_id }}"
                value="{% if form.name %}{{ form.name }}{% endif %}"
                required
                aria-required="true"
              >
            </div>

            <div class="ai-contact-form-field-{{ ai_gen_id }}">
              <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
                Email <span aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="contact-email-{{ ai_gen_id }}"
                name="contact[email]"
                class="ai-contact-form-input-{{ ai_gen_id }}"
                value="{% if form.email %}{{ form.email }}{% endif %}"
                required
                aria-required="true"
                autocomplete="email"
              >
            </div>

            <div class="ai-contact-form-field-{{ ai_gen_id }}">
              <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-phone-{{ ai_gen_id }}"> Phone </label>
              <input
                type="tel"
                id="contact-phone-{{ ai_gen_id }}"
                name="contact[phone]"
                class="ai-contact-form-input-{{ ai_gen_id }}"
                value="{% if form.phone %}{{ form.phone }}{% endif %}"
                autocomplete="tel"
              >
            </div>

            <div class="ai-contact-form-field-{{ ai_gen_id }}">
              <label class="ai-contact-form-label-{{ ai_gen_id }}" for="contact-message-{{ ai_gen_id }}">
                Message <span aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message-{{ ai_gen_id }}"
                name="contact[body]"
                class="ai-contact-form-textarea-{{ ai_gen_id }}"
                required
                aria-required="true"
              >{% if form.body %}{{ form.body }}{% endif %}</textarea>
            </div>

            <button type="submit" class="ai-contact-form-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </button>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>"
    },
    {
      "type": "header",
      "content": "Contact information"
    },
    {
      "type": "text",
      "id": "phone_1",
      "label": "Phone number 1"
    },
    {
      "type": "text",
      "id": "phone_2",
      "label": "Phone number 2"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media icons",
      "default": true,
      "info": "Configure social media links in theme settings"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "custom_code",
          "label": "Custom code"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Displayed when media type is set to Image"
    },
    {
      "type": "html",
      "id": "custom_code",
      "label": "Custom code",
      "info": "Add custom HTML/embed code (e.g., Google Maps). Displayed when media type is set to Custom code"
    },
    {
      "type": "header",
      "content": "Form settings"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Send Message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for contacting us. We'll get back to you soon!"
    }
  ],
  "presets": [
    {
      "name": "Contact section"
    }
  ]
}
{% endschema %}
