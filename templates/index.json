eObserver(updateValues);\n  slide1 && ro.observe(slide1);\n  slide3 && ro.observe(slide3);\n})();\n</script>\n<svg style=\"margin-bottom:-1px;\" viewBox=\"0 0 1920 116\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<mask id=\"mask0_1086_121\" style=\"mask-type:alpha\" maskUnits=\"userSpaceOnUse\" x=\"0\" y=\"0\" width=\"1920\" height=\"116\">\n<rect width=\"1920\" height=\"116\" fill=\"#D9D9D9\"/>\n</mask>\n<g mask=\"url(#mask0_1086_121)\">\n<path d=\"M981.633 48.4896C1554.63 21.1019 1802.22 91.5596 1920 115.387L1920 988.206C1920 988.206 0.000244141 991.009 0.000244141 989.608L0 0C127.356 56.2986 673.678 63.2089 981.633 48.4896Z\" fill=\"#F8EDDB\"/>\n</g>\n</svg>"
