        "text_gGEQiK": {
          "type": "text",
          "settings": {
            "text": "<p>We bring you the world’s exclusive honey- produced by the largest honeybees of the world and harvested by native Himalayan honey hunters in the traditional way. Our purpose, at Himalayan Cliff Honey, lies in bringing nature's uncommon, limited honey from Himalayan cliffs to jars. Each jar carries an ancient legacy- a symbol of the timeless bond between Himalayan bees and honey hunters that existed for ages.</p>",
            "text_style": "body"
          }
        }
