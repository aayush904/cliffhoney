x);\nfont-weight: 600;\n}\n\n.two-col-list {\n  column-count: 2;\n  column-gap: 20px;\n  padding: 0;\n  list-style-type:disc;\n  margin: 0;\n  margin-left:1.5em;\n}\n\n.two-col-list li {\n  -webkit-column-break-inside: avoid;      \n  margin-bottom: 6px;\n  font-size: 15px;\nlist-style-type:disc;\n}\n\n#collapsible_calc_section button{\nmin-width:100%;\n}\n\n@media(min-width:768px){\n#collapsible_calc_section *:not(.button){\ntext-align:start;\n}\n}\n\n</style>"
