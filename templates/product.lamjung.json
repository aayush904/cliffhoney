    "custom_liquid_HDNkCG": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<script>\nclass CollapsibleManager extends HTMLElement {\n  connectedCallback() {\n    const sections = document.querySelectorAll('.collapsible_sections');\n    const buttons = [];\n\n    sections.forEach(sec => {\n      const h2 = sec.querySelector('h2');\n      const title = h2 ? h2.textContent.trim() : \"Untitled\";\n\n      const btn = document.createElement('button');\n      btn.textContent = title;\n      btn.className = 'collapse-btn';\n      this.appendChild(btn);\n      buttons.push({ btn, sec });\n\n      // Initially hide all sections\n      sec.style.display = \"none\";\n\n      btn.addEventListener('click', () => {\n        const isMobile = window.innerWidth < 768;\n\n        if (isMobile) {\n          // Toggle visibility on mobile\n          const visible = sec.style.display === \"block\";\n          sec.style.display = visible ? \"none\" : \"block\";\n        } else {\n          // On desktop, show clicked section and hide others\n          buttons.forEach(({ btn: b, sec: s }) => {\n            s.style.display = s === sec ? \"block\" : \"none\";\n          });\n        }\n      });\n    });\n\n    // Optional: On desktop load, show first section by default\n    if (window.innerWidth >= 768 && sections.length) {\n      sections.forEach((sec, i) => {\n        sec.style.display = i === 0 ? \"block\" : \"none\";\n      });\n    }\n\n    // Optional: Update on window resize\n    window.addEventListener('resize', () => {\n      if (window.innerWidth >= 768 && sections.length) {\n        // On desktop: only show first visible section or first by default\n        let visibleFound = false;\n        sections.forEach(sec => {\n          if (sec.style.display === \"block\") visibleFound = true;\n        });\n        if (!visibleFound) {\n          sections.forEach((sec, i) => {\n            sec.style.display = i === 0 ? \"block\" : \"none\";\n          });\n        }\n      }\n    });\n  }\n}\n\ncustomElements.define('collapsible-manager', CollapsibleManager);\n\n\n</script>\n<collapsible-manager></collapsible-manager>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 50
      }
    },
