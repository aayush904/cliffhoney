            "custom_liquid": "<div class=\"mh-row animate--slide-in\">\n  <div class=\"mh-field\">\n    <label>Your age range</label>\n    <select class=\"ageRange\">\n      <option value=\"Under Age\">Under Age</option>\n      <option value=\"Adult 18+\">Adult 18+</option>\n    </select>\n  </div>\n\n\n  <div class=\"mh-field\">\n    <label>Your weight range</label>\n    <select class=\"weightRange\">\n      <option value=\"40-60\">40-60</option>\n      <option value=\"61-80\">61-80</option>\n      <option value=\"81-100\">81-100</option>\n      <option value=\"100+\">100+</option>\n    </select>\n  </div>\n</div>\n<button class=\"animate--slide-in button button-primary\">Calculate</button>\n<style>\n.mh-row {\n  width:100%;\n  display: flex;\n--gap:clamp(12px,1.25vw,24px);\n  gap: var(--gap);\n  align-items: flex-start;\nmargin:clamp(24px,1.67vw,32px) 0;\n}\n\n.mh-field label {\n  font-size: calc(14px,1.6vw,24px);\n  font-weight: 500;\n}\n\n.mh-field .highlight {\n  color: var(--color-extra); \n}\n\n.mh-field {\n  position: relative;\nwidth:calc(50% - var(--gap)/2);\n}\n\n.mh-field select {\n  margin-top: 8px;\n  width: 150px;\n  padding: clamp(12.5px,1.15vw,22px);\npadding-right:45px;\n  border-radius: 30px;\n  border: 1px solid rgba(var(--color-button),1);\n  font-size: 15px;\n  appearance: none;\n  cursor: pointer;\n  background: transparent;\n width: 100%;\n  background-image: url(\"data:image/svg+xml;utf8,<svg width='18' height='18' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'><path d='M1 7L12 18L23 7' stroke='%233D3939' stroke-width='2'/></svg>\");\n  background-repeat: no-repeat;\n  background-position: right clamp(12px,1.31vw,25px) center;\n  background-size: clamp(12px,0.84vw,16px);\n}\n\n.mh-field select {\nbox-shadow:none!important;\n  outline:none!important\n}\n\n#result {\n  margin-top: 20px;\n  color: #333;\n}\n\nh4{\nfont-family:var(--font-body-family);\nmargin-top: clamp(24px,1.67vw,32px);\nmargin-bottom: clamp(16px,1.25vw,24px);\nfont-weight: 600;\n}\n\n.two-col-list {\n  column-count: 2;\n  column-gap: 20px;\n  padding: 0;\n  list-style-type:disc;\n  margin: 0;\n  margin-left:1.5em;\n}\n\n.two-col-list li {\n  -webkit-column-break-inside: avoid;      \n  margin-bottom: 6px;\n  font-size: 15px;\nlist-style-type:disc;\n}\n\n#collapsible_calc_section button{\nmin-width:100%;\n}\n\n@media(min-width:768px){\n#collapsible_calc_section *:not(.button){\ntext-align:start;\n}\n}\n\n</style>"
          }
        },
