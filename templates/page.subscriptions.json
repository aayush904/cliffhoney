        "row_cfxqaa": {
          "type": "row",
          "settings": {
            "custom_liquid": "<h2>Why we love it</h2>\n<div style=\"overflow:visible; display:grid; grid-template-columns:1fr 1fr; gap:clamp(16px,1.67vw,32px)\">\n<div>\n<svg viewBox=\"0 0 98 98\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<circle cx=\"49\" cy=\"49\" r=\"48.5\" stroke=\"#FEF0D2\"/>\n</svg>\n<h4>Keep your honey stocked at the best price.</h4>\n<p>Save 10% free shipping within US in every recurring Order</p>\n</div>\n\n<div>\n<svg viewBox=\"0 0 98 98\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<circle cx=\"49\" cy=\"49\" r=\"48.5\" stroke=\"#FEF0D2\"/>\n</svg>\n\n\n<h4>Be the First to taste our rarest honey</h4>\n<p>Cliff Honey subscribers receive early\naccess to new launches</p>\n\n\n</div>\n\n\n<div>\n<svg viewBox=\"0 0 98 98\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<circle cx=\"49\" cy=\"49\" r=\"48.5\" stroke=\"#FEF0D2\"/>\n</svg>\n\n<h4>A Little extra something from time to time.</h4>\n<p>We love to show appreciation to our subscribers with discounts and more</p>\n</div>\n\n\n<div>\n<svg  viewBox=\"0 0 98 98\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<circle cx=\"49\" cy=\"49\" r=\"48.5\" stroke=\"#FEF0D2\"/>\n</svg>\n\n<h4>Stress Free- no string attached.</h4>\n<p>Early ship order. Cancel your subscription at any time.</p>\n</div>\n</div>\n<style>\n.white *{\ncolor:#ffffff;\nletter-spacing:0;\n}\n.white svg{\n width:10px;\n stroke-width:24px;\nborder-radius:50%;\nmargin:0!important;\nmargin-left: -15px!important;\n//width:clamp(48px,5.12vw,98px)\n\n}\n.white svg, .white h4{\ndisplay:inline;\nmargin-bottom: clamp(8px,0.84vw,16px)\n}\n</style>",
