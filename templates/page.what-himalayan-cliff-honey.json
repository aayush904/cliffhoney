    "rich_text_xmpCmY": {
      "type": "rich-text",
      "blocks": {
        "heading_dbdaFV": {
          "type": "heading",
          "settings": {
            "heading": "The <strong>Ancient Tradition</strong> of Honey Hunting",
            "heading_size": "h2"
          }
        },
        "text_6Q4EK8": {
          "type": "text",
          "settings": {
            "text": "<p>High in the rugged cliffs of the Himalayas, a centuries-old practice continues to thrive- honey hunting; one of the world’s most daring and sacred traditions.</p>"
          }
        }
      },
      "block_order": [
        "heading_dbdaFV",
