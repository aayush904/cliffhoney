    "image_with_text_xkmE8r": {
      "type": "image-with-text",
      "blocks": {
        "heading_MeyNqJ": {
          "type": "heading",
          "settings": {
            "heading": "The Regional <strong>Reserve Collection.</strong>",
            "heading_size": "h2"
