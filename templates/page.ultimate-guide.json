        "custom_liquid": "<script>\n(function () {\n  function replaceFAQSection() {\n    var chapter = document.querySelector('.chapter-section');\n    var collapsible = document.querySelector('[id*=\"__collapsible_content\"]');\n\n    if (!chapter || !collapsible) return false;\n\n    var walker = document.createTreeWalker(\n      chapter,\n      NodeFilter.SHOW_TEXT,\n      null,\n      false\n    );\n\n    var node;\n    while ((node = walker.nextNode())) {\n      if (node.nodeValue.includes('[FAQ_SECTION]')) {\n\n        // Clone the collapsible\n        var clone = collapsible.cloneNode(true);\n        var wrapper = document.createElement('span');\n        wrapper.appendChild(clone);\n\n        var parts = node.nodeValue.split('[FAQ_SECTION]');\n        node.nodeValue = parts[0];\n\n        node.parentNode.insertBefore(wrapper, node.nextSibling);\n\n        if (parts[1]) {\n          node.parentNode.insertBefore(\n            document.createTextNode(parts[1]),\n            wrapper.nextSibling\n          );\n        }\n\n        // 🔥 Remove original collapsible after successful copy\n        collapsible.remove();\n\n        return true;\n      }\n    }\n    return false;\n  }\n\n  function init() {\n    if (replaceFAQSection()) return;\n\n    var observer = new MutationObserver(function () {\n      if (replaceFAQSection()) observer.disconnect();\n    });\n\n    observer.observe(document.body, {\n      childList: true,\n      subtree: true\n    });\n  }\n\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', init);\n  } else {\n    init();\n  }\n})();\n</script>",
