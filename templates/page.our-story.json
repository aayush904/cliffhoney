        "section_class": "hover-active",
        "custom_code": "{% assign secid= '#shopify-section-' | append: section.id %}\n\n<style>\n{{ secid }} .content-container:after {\n  content:none;\n}\n{{ secid }} h2{\nmargin-bottom: clamp(16px, 1.67vw, 32px);\n}\n{{ secid }} ul .multicolumn-card .custom-code > p{\nmax-width:90%;\nmargin:6px auto auto;\n    font-size: clamp(1rem, 0.94vw, 1.8rem);\npadding-top:clamp(2px,0.21vw,4px);\n}\n\n{{ secid }} img{\nmix-blend-mode:multiply;\n}\n\n{{ secid }} .multicolumn__title{\njustify-content:center;\nmargin-bottom: clamp(24px,4.18vw,80px);\ntext-align:center;\n}\n\n{{ secid }} .multicolumn__title p{\nmargin:0;\n}\n\n{{secid}} ul ul{\npadding:0;\n max-width: max-content;\n margin:0 auto;\n}\n\n{{secid}} .multicolumn-card-spacing{\nmargin:0;\npadding: clamp(16px, 1.67vw, 32px) clamp(8px, 1.25vw, 24px);\npadding-top:0;\n;\n}\n{{secid}} ul ul li {\n    text-align: left;\n    max-width:max-content;\n    list-style: none;\n    display: flex;\n    margin: 0;\n    margin-bottom: clamp(8px,0.63vw,12px);\n    gap: 12px;\n    align-items: center;\n    font-size: clamp(1rem, 1.05vw, 2rem);\n}\n\n{{secid}} ul ul li svg {\nwidth:clamp(18px,2.51vw,48px);\nheight:clamp(18px,2.51vw,48px);\nfill:transparent;\n}\n\n{{secid}} li .stars{\nwidth:auto;\naspect-ratio:128/24;\nheight: clamp(16px,1.25vw,24px);\n}\n\n{{ secid }} .multicolumn-card {\n  border-radius: 16px;\n  outline: 2px solid transparent;\n    outline-offset: -2px;\n  background: #ffecc3;\n  transition: all 0.5s ease;\n  opacity: 0.6 !important;\n}\n\n{{ secid }} li.is-active .multicolumn-card{\n  opacity: 1!important;\n  outline: 2px solid #B5731F99;\n\n}\n\n{{ secid }} .grid {\n  flex-wrap: nowrap;\n  gap: 0;\n  justify-content: space-between;\n}\n{{secid}} .splide__slide {\nmargin-right:clamp(16px,1.25vw,24px);}\n.multicolumn-card__info > :nth-child(2){\nmargin-top:clamp(10px,0.84vw,16px);\n}\n@media(max-width:768px){\n{{ secid }} .multicolumn-card {\nmin-width:58.75dvw;\n\n}}\n</style>\n\n{{ 'splide.min.css' | asset_url | stylesheet_tag }}\n<script src=\"{{ 'splide.min.js' | asset_url }}\" defer></script>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function () {\n  if (typeof Splide === 'undefined') return;\n\n  var sectionRoot = document.getElementById('shopify-section-{{ section.id }}');\n  if (!sectionRoot) return;\n  var list = sectionRoot.querySelector('ul[id^=\"Slider-\"]');\n  if (!list || list.closest('.splide')) return;\n\n  // Add splide classes + our own stable index\n  var items = Array.prototype.slice.call(list.children);\n  list.classList.add('splide__list');\n  items.forEach(function (li, i) {\n    li.classList.add('splide__slide');\n    li.setAttribute('data-nav-index', String(i));\n    li.style.cursor = 'pointer';\n  });\n\n  // Wrap with splide structure\n  var track = document.createElement('div');\n  track.className = 'splide__track';\n\n  var root = document.createElement('div');\n  root.className = 'splide';\n\n  list.parentNode.insertBefore(root, list);\n  root.appendChild(track);\n  track.appendChild(list);\n\n  var splide = new Splide(root, {\n    perPage: 3,\n    focus: 'center',\npadding: { left: '16px', right: '16px' },\n    pagination: false,\n    arrows: false,\n    breakpoints: {\n      990: {\n        perPage: 3,\n        type: 'loop',\n      },\n      768: {\n        perPage: 1,\n        type: 'loop',\n        focus: 'center',\npadding: { left: '18.5vw', right: '18.5vw' },\n        gap:'16px',\n      }\n    }\n  });\n\n  function getTargetIndex(slideEl) {\n    // Prefer our stable index (original slides)\n    var v = slideEl.getAttribute('data-nav-index');\n    if (v != null) return parseInt(v, 10);\n\n    // Fallback (for clones if Splide adds them)\n    v = slideEl.getAttribute('data-splide-index');\n    if (v != null) return parseInt(v, 10);\n\n    return null;\n  }\n\n  function goToSlideFromEvent(e) {\n    var slide = e.target.closest('.splide__slide');\n    if (!slide || !root.contains(slide)) return;\n\n    var idx = getTargetIndex(slide);\n    if (idx == null || Number.isNaN(idx)) return;\n\n    splide.go(idx);\n  }\n\n  splide.on('mounted', function () {\n    // CLICK -> activate slide\n    root.addEventListener('click', function (e) {\n      // If your slide contains <a> and you still want navigation, remove next 3 lines.\n      var link = e.target.closest('a');\n      if (link && !(e.metaKey || e.ctrlKey || e.shiftKey || e.altKey)) e.preventDefault();\n\n      goToSlideFromEvent(e);\n    }, true);\n\n    // HOVER -> activate slide (desktop only)\nif (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {\n  root.addEventListener('pointerenter', function (e) {\n    var slide = e.target.closest('.splide__slide');\n    if (!slide || !root.contains(slide)) return;\n\n    // Prefer Splide's index (works on clones)\n    var idx = slide.getAttribute('data-splide-index');\n    if (idx == null) idx = slide.getAttribute('data-nav-index');\n    if (idx == null) return;\n\n    splide.go(parseInt(idx, 10));\n  }, true);\n}\n\n  });\n  splide.mount();\n});\n</script>"
      }
