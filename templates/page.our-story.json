        "text_Wxz6Ty": {
          "type": "text",
          "disabled": true,
          "settings": {
            "text": "<p>This selected bundle is designed for those who want to experience the true diversity of Nepali honey. From the wild himalayan Apis laboriosa colonies in <em>Lamjung</em>, <em>Jajarkot</em>, and <em>Rukum</em>, each jar offers a rare taste, texture, where altitude, wild flora, and season shape the honey’s character.</p>",
            "text_style": "body"
          }
        },
        "liquid_G7V689": {
          "type": "Liquid",
          "settings": {
            "custom_liquid": "<div class=\"custom\"><h4>Includes:</h4>\n<hr/>\n\n<p><strong>Lamjung Cliff Honey <svg width=\"29\" height=\"14\" viewBox=\"0 0 29 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<g clip-path=\"url(#clip0_5529_17217)\">\n<path d=\"M3.1295 14L7.51079 9.14851L10.7562 12.7987L15.7634 4.38944L17.4788 7.0462L19.3333 4.9901L26.1023 14H29L19.5188 1.36304L17.8034 3.25743L15.6938 0L10.3853 8.89439L7.51079 5.66007L0 14H3.1295Z\" fill=\"#B5731F\"/>\n</g>\n<defs>\n<clipPath id=\"clip0_5529_17217\">\n<rect width=\"29\" height=\"14\" fill=\"white\"/>\n</clipPath>\n</defs>\n</svg>\n<highlight>Alt. 4000m</highlight>\n</strong>\nBright, aromatic, and balanced</p>\n\n<p><strong>Rukum Cliff Honey <svg width=\"29\" height=\"14\" viewBox=\"0 0 29 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<g clip-path=\"url(#clip0_5529_17217)\">\n<path d=\"M3.1295 14L7.51079 9.14851L10.7562 12.7987L15.7634 4.38944L17.4788 7.0462L19.3333 4.9901L26.1023 14H29L19.5188 1.36304L17.8034 3.25743L15.6938 0L10.3853 8.89439L7.51079 5.66007L0 14H3.1295Z\" fill=\"#B5731F\"/>\n</g>\n<defs>\n<clipPath id=\"clip0_5529_17217\">\n<rect width=\"29\" height=\"14\" fill=\"white\"/>\n</clipPath>\n</defs>\n</svg>\n<highlight>Alt. 3800m</highlight>\n</strong>\nEarthy & layered, from high-altitude forests</p>\n\n<p><strong>Jajarkot Cliff Honey <svg width=\"29\" height=\"14\" viewBox=\"0 0 29 14\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n<g clip-path=\"url(#clip0_5529_17217)\">\n<path d=\"M3.1295 14L7.51079 9.14851L10.7562 12.7987L15.7634 4.38944L17.4788 7.0462L19.3333 4.9901L26.1023 14H29L19.5188 1.36304L17.8034 3.25743L15.6938 0L10.3853 8.89439L7.51079 5.66007L0 14H3.1295Z\" fill=\"#B5731F\"/>\n</g>\n<defs>\n<clipPath id=\"clip0_5529_17217\">\n<rect width=\"29\" height=\"14\" fill=\"white\"/>\n</clipPath>\n</defs>\n</svg>\n<highlight>Alt. 3500m</highlight>\n</strong>\nDeep, bold, and intense, collected from remote western Himalayan cliffs.</p>\n<hr/>\n<p><strong>Luxury Gift Box Set</strong>\nDesigned for protection, presentation, and gifting.\n</p>\n<hr/>\n<p><strong>Hand-crafted Wooden Spoon</strong>\nFor a gentle, precise daily serving.</p>\n<hr/>\n</div>"
          }
