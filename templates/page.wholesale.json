    "multicolumn_V9ajcD": {
      "type": "multicolumn",
      "blocks": {
        "column_VDGq8a": {
          "type": "column",
          "settings": {
            "title": "",
            "text": "",
            "link_label": "",
            "link": "",
            "custom_liquid": "<h2>**Please note the following terms for Cliff  Honey Wholesale purchases**</h2>\n<p>\nInternational freight costs are regularly changing, while we can discuss your options with you it is your responsibility to find the solution that best suits you.\n</p>\n<p>\nAll quotes will be provided in USD dollars.\n</p>\n\n<p>\nInternational transaction fees including fees for importation and customs clearances are the responsibility of the purchaser. Further to this the purchaser is required to adhere to all local government requirements in regards to FDA approvals and similar\n</p>"
          }
        },
        "column_UehXc8": {
          "type": "column",
          "settings": {
            "title": "",
            "text": "",
            "link_label": "",
            "link": "",
            "custom_liquid": "<p>\nPurchasers are not permitted to sell on marketplaces like ebay, Amazon Walmart, Etsy . Neither the wholesale customer or their customers are permitted to sell on marketplace platforms.\n</p>\n<p>\nWhile we will supply all relevant testing documentation we have, where there are further requirements requested for the country wise certification process we will accommodate as best we can but can not guarantee that you will not have to carry out your own tests or certifications to comply with local legislation.\n</p>\n<p>\n<highlight>Note:</highlight> We look forward to starting the conversation and looking at possibilities for Mad Honey wholesale opportunities with you. Get in touch with one of the team by using the contact form below.</p>"
          }
        }
      },
