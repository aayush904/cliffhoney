    "image_with_text_7VVTnf": {
      "type": "image-with-text",
      "blocks": {
        "heading_8tVcNw": {
          "type": "heading",
          "settings": {
            "heading": "What are all of the benefits of<strong> Himalayan Cliff Honey</strong>?",
            "heading_size": "h2"
          }
        },
        "text_4VPXEw": {
          "type": "text",
          "settings": {
            "text": "<p><strong>We provide premium Himalayan cliff honey for wholesale and private label that can be customized upon the needs of the client.</strong><br/><br/>Himalayan Cliff Honey is an authentic cliff honey producer, extracted from thousands of metres above in the Himalayas.<br/><br/>The core of our brand lies in our rare and unmatched harvesting sites that are in the remote, far-flung villages of Nepal: Lamjung, Jajarkot and Rukum. The sites are selected and curated based on the altitudes, ranging from 3000 to 4000 metres, known for producing the best quality mad honey in the whole country. We use completely traditional methods upholding a promise of quality in every drop. Unprocessed and pure, our honey comes with certificates of laboratory analysis and QR codes, adding an extra layer of transparency and trust for users. Our products are even recognized and approved by the Nepal Government.</p>",
            "text_style": "body"
          }
        },
        "liquid_JtzbmQ": {
          "type": "Liquid",
          "settings": {
            "custom_liquid": "<div class=\"buttons\">\n<a href=\"#private\" class=\"button\">Private Labeling</a> \n<a href=\"#distributor\" class=\"button\">Distributor</a>\n</div>"
          }
        }
      },
