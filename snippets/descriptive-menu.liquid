{%- comment -%}
  Snippet: descriptive-menu.liquid
  Inputs:
    - parent_link (required)
    - block (required)
    - mode: 'mega' | 'drawer' (required)

  Usage:
    Displays child links as descriptive cards with images, titles, and descriptions.
    Only shows direct children (no grandchildren).
{%- endcomment -%}

{%- assign uid = 'dmenu-'
  | append: parent_link.title
  | handleize
  | append: '-'
  | append: block.id
  | append: '-'
  | append: mode
-%}

{% if mode == 'mega' %}
  {% style %}
    .descriptive-menu {
      --dm-gap: 8px;
      --dm-text: #000000;
      --dm-subtext: rgba(var(--color-foreground), 0.65);
      --dm-accent: var(--color-extra);
    }

    .descriptive-menu .dm-container {
      max-width: clamp(1080px, 68.37vw, 1308px);
      margin: 0 auto;
      padding: 0 1.6rem;
    }

    .descriptive-menu .dm-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--dm-gap);
    }

    @media screen and (max-width: 900px) {
      .descriptive-menu .dm-grid {
        grid-template-columns: 1fr;
      }
    }

    .descriptive-menu .dm-card {
      text-decoration: none;
      color: inherit;
      display: flex;
      gap: 24px;
      align-items: center;
      padding: 2.4rem;
      border-radius: 16px;
      border: none;
      box-shadow: none;
    }

    .descriptive-menu .dm-card:hover {
      background-color: #ffffff;
      box-shadow: 4px 4px 14.4px rgba(0, 0, 0, 0.1);
    }

    .descriptive-menu .dm-card:hover .dm-card-link {
      gap: 1rem;
    }

    .descriptive-menu .dm-card-image {
      width: clamp(120px, 13.07vw, 250px);
      height: clamp(120px, 13.07vw, 250px);
      flex-shrink: 0;
      overflow: hidden;
      border-radius: 16px;
      background: #e5e5e5;
    }

    .descriptive-menu .dm-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .descriptive-menu .dm-card-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 5px;
      text-align: left;
      padding: 0.25rem 0;
    }

    .descriptive-menu .dm-card-title {
      font-size: clamp(12px, 1.568vw, 30px);
      font-weight: 700;
      margin: 0 !important;
      line-height: 1.3;
      text-align: left;
      letter-spacing: 0;
      font-family: var(--font-heading-family);
      color: rgba(var(--color-foreground), 1);
      position: relative;
      width: max-content;
    }

    .descriptive-menu .dm-card-title::after {
      width: 100%;
      height: 2px;
      content: '';
      position: absolute;
      bottom: 1px;
      left: 0;
      background-color: var(--color-extra);
      display: none;
    }

    .descriptive-menu .dm-card-title:hover:after {
      display: inline-block;
    }

    .descriptive-menu .dm-card-description {
      line-height: 1.4;
      letter-spacing: 0;
      color: var(--dm-subtext);
      margin: 0;
      -webkit-line-clamp: 3;
      display: -webkit-box;
      overflow: hidden;
      text-overflow: ellipsis;
      word-wrap: break-word;
      line-height: 1.2;
      word-break: break-word;
    }

    .descriptive-menu .dm-card-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 12px;
      color: var(--dm-accent);
      font-weight: 500;
      text-decoration: none;
      transition: gap 0.2s ease;
    }

    .descriptive-menu .dm-card-link svg {
      width: 14px;
      height: 14px;
    }
  {% endstyle %}
{% endif %}

<div id="{{ uid }}" class="descriptive-menu dmenu-{{ mode }}" data-dmenu-root data-dmenu-mode="{{ mode }}">
  {%- if mode == 'mega' -%}
    {%- comment -%} ===== Desktop mega layout ===== {%- endcomment -%}
    <div class="dm-container">
      <div class="dm-grid">
        {%- for child in parent_link.links -%}
          {%- liquid
            assign child_type = 'link'
            assign child_handle = ''
            assign child_image = null
            assign child_description = ''

            if child.url contains '/collections/'
              assign child_type = 'collection'
              assign parts = child.url | split: '/collections/'
              assign child_handle = parts[1] | split: '/' | first
              if collections[child_handle] != blank
                assign c = collections[child_handle]
                assign child_image = c.metafields.custom.menu_image.value | default: c.metafields.custom.menu_image | default: c.featured_image
                assign child_description = c.description | strip_html | truncate: 120
              endif
            elsif child.url contains '/blogs/'
              assign child_type = 'blog'
              assign parts = child.url | split: '/blogs/'
              assign child_handle = parts[1] | split: '/' | first
              if blogs[child_handle] != blank
                assign b = blogs[child_handle]
                assign child_image = b.metafields.custom.menu_image.value | default: b.metafields.custom.menu_image | default: b.image
                assign child_description = b.metafields.custom.excerpt.value  | strip_html | truncate: 120
              endif
            elsif child.url contains '/products/'
              assign child_type = 'product'
              assign parts = child.url | split: '/products/'
              assign child_handle = parts[1] | split: '/' | first
              assign prod = all_products[child_handle]
              if prod != blank
                assign child_image = prod.metafields.custom.menu_image.value | default: prod.metafields.custom.menu_image | default: prod.featured_image
                assign child_description = prod.description | strip_html | truncate: 120
              endif
            elsif child.url contains '/pages/'
              assign child_type = 'page'
              assign parts = child.url | split: '/pages/'
              assign child_handle = parts[1] | split: '/' | first
              if pages[child_handle] != blank
                assign page_obj = pages[child_handle]
                assign child_image = page_obj.metafields.custom.menu_image.value | default: page_obj.metafields.custom.menu_image | default: page_obj.image
                assign child_description = page_obj.content | strip_html | truncate: 120
              endif
            endif
          -%}

          <a href="{{ child.url }}" class="dm-card">
            <div class="dm-card-image">
              {%- if child_image -%}
                <img
                  src="{{ child_image | image_url: width: 320 }}"
                  alt="{{ child.title | escape }}"
                  loading="lazy"
                  width="320"
                  height="320"
                >
              {%- else -%}
                <img
                  src="https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-image_large.png"
                  alt="{{ child.title | escape }}"
                  loading="lazy"
                  width="320"
                  height="320"
                >
              {%- endif -%}
            </div>
            <div class="dm-card-content">
              <div class="dm-card-title">{{ child.title | escape }}</div>
              {%- if child_description != blank -%}
                <p class="dm-card-description">{{ child_description }}</p>
              {%- else -%}
                <p class="dm-card-description">
                  Himalayan cliff honey is a rare and exquisite wild honey variety collected from huge hives of Apis
                  l...
                </p>
              {%- endif -%}
              <span class="dm-card-link"> Learn More → </span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    </div>

  {%- elsif mode == 'drawer' -%}
    {%- comment -%} ===== Mobile drawer layout ===== {%- endcomment -%}
    {% style %}
      .descriptive-menu.dmenu-drawer {
        --dm-gap: 0.75rem;
      }

      .descriptive-menu.dmenu-drawer .dm-drawer-container {
        padding: 0 12px;
        padding-bottom: 12px;
      }

      [data-dmenu-mode='drawer'] .menu-opening[open] summary .sidebar-arrow {
        transform: rotate(90deg);
      }

      .descriptive-menu.dmenu-drawer .dm-drawer-container hr {
        margin: 0 auto;
        margin-bottom: 20px;
        width: 95%;
        height: 1px;
        background-color: rgba(0, 0, 0, 0.4);
      }

      .descriptive-menu.dmenu-drawer .dm-drawer-list {
        display: flex;
        flex-direction: column;
        gap: var(--dm-gap);
      }

      .descriptive-menu.dmenu-drawer .dm-card {
        text-decoration: none;
        color: inherit;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.25rem 0;
        background: transparent;
        border: none;
      }

      .descriptive-menu.dmenu-drawer .dm-card-image {
        width: 38px;
        height: 38px;
        flex-shrink: 0;
        overflow: hidden;
        border-radius: 8px;
      }

      .descriptive-menu.dmenu-drawer .dm-card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .descriptive-menu.dmenu-drawer .dm-card-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .descriptive-menu.dmenu-drawer .dm-card-title {
        letter-spacing: 0;
        font-size: clamp(16px, 1.25vw, 24px);
        font-family: var(--font-heading-family);
        text-align: left;
        font-weight: 700;
        padding-left: 2px;
        margin-bottom: 4px;
      }

      .descriptive-menu.dmenu-drawer .dm-card-description {
        font-size: 0.85rem;
        line-height: 1.4;
        color: #666;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .descriptive-menu.dmenu-drawer .dm-card-arrow {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        color: #d97706;
      }

      .descriptive-menu.dmenu-drawer .dm-card-arrow svg {
        width: 20px;
        height: 20px;
      }
    {% endstyle %}

    <details id="Details-menu-drawer-{{ uid }}">
      <summary
        id="HeaderDrawer-{{ parent_link.handle }}"
        class="sidebar-item menu-drawer__menu-item list-menu__item link link--text focus-inset{% if parent_link.child_active %} menu-drawer__menu-item--active{% endif %}"
      >
        {%- if block.settings.descriptive_image != blank -%}
          <img
            width=""
            height=""
            src="{{ block.settings.descriptive_image | image_url: width: 98 }}"
            alt="{{ parent_link.title | escape }}"
            loading="lazy"
          >
        {%- else -%}
          <img width="" height="" src="https://via.placeholder.com/48" alt="placeholder" loading="lazy">
        {%- endif -%}
        {{ parent_link.title | escape }}
        <div class="sidebar-arrow">›</div>
      </summary>
      <div
        id="link-{{ parent_link.handle | escape }}"
        class="menu-drawer__submenu has-submenu gradient motion-reduce"
        tabindex="-1"
      >
        <div class="menu-drawer__inner-submenu">
          {% comment %}
            <button class="menu-drawer__close-button link link--text focus-inset" aria-expanded="true">
              <span class="svg-wrapper">
                {{- 'icon-arrow.svg' | inline_asset_content -}}
              </span>
              {{ parent_link.title | escape }}
            </button>
          {% endcomment %}

          <div class="dm-drawer-container">
            <hr>
            <div class="dm-drawer-list">
              {%- for child in parent_link.links -%}
                {%- liquid
                  assign child_type = 'link'
                  assign child_handle = ''
                  assign child_image = null
                  assign child_description = ''

                  if child.url contains '/collections/'
                    assign child_type = 'collection'
                    assign parts = child.url | split: '/collections/'
                    assign child_handle = parts[1] | split: '/' | first
                    if collections[child_handle] != blank
                      assign c = collections[child_handle]
                      assign child_image = c.metafields.custom.menu_image.value | default: c.metafields.custom.menu_image | default: c.featured_image
                      assign child_description = c.description | strip_html | truncate: 80
                    endif
                  elsif child.url contains '/blogs/'
                    assign child_type = 'blog'
                    assign parts = child.url | split: '/blogs/'
                    assign child_handle = parts[1] | split: '/' | first
                    if blogs[child_handle] != blank
                      assign b = blogs[child_handle]
                      assign child_image = b.metafields.custom.menu_image.value | default: b.metafields.custom.menu_image | default: b.image
                      assign child_description = b.metafields.custom.excerpt.value | strip_html | truncate: 80
                    endif
                  elsif child.url contains '/products/'
                    assign child_type = 'product'
                    assign parts = child.url | split: '/products/'
                    assign child_handle = parts[1] | split: '/' | first
                    assign prod = all_products[child_handle]
                    if prod != blank
                      assign child_image = prod.metafields.custom.menu_image.value | default: prod.metafields.custom.menu_image | default: prod.featured_image
                      assign child_description = prod.description | strip_html | truncate: 80
                    endif
                  elsif child.url contains '/pages/'
                    assign child_type = 'page'
                    assign parts = child.url | split: '/pages/'
                    assign child_handle = parts[1] | split: '/' | first
                    if pages[child_handle] != blank
                      assign page_obj = pages[child_handle]
                      assign child_image = page_obj.metafields.custom.menu_image.value | default: page_obj.metafields.custom.menu_image | default: page_obj.image
                      assign child_description = page_obj.content | strip_html | truncate: 80
                    endif
                  endif
                -%}

                <a href="{{ child.url }}" class="dm-card">
                  <div class="dm-card-image">
                    {%- if child_image -%}
                      <img
                        src="{{ child_image | image_url: width: 160 }}"
                        alt="{{ child.title | escape }}"
                        loading="lazy"
                        width="80"
                        height="80"
                      >
                    {%- else -%}
                      <img
                        src="https://cdn.shopify.com/s/files/1/0533/2089/files/placeholder-images-image_large.png"
                        alt="{{ child.title | escape }}"
                        loading="lazy"
                        width="80"
                        height="80"
                      >
                    {%- endif -%}
                  </div>
                  <div class="dm-card-content">
                    <div class="dm-card-title">{{ child.title | escape }}</div>
                    {%- if child_description != blank -%}
                      <p class="dm-card-description">{{ child_description }}</p>
                    {%- endif -%}
                  </div>
                  <div class="sidebar-arrow">›</div>
                </a>
              {%- endfor -%}
            </div>
          </div>
        </div>
      </div>
    </details>
  {%- endif -%}
</div>
