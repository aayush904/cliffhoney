{%- comment -%}
  Renders the vertical "Frequently bought together" sidebar for the two-column cart drawer

  Usage:
  {% render 'cart-drawer-sidebar-fbt', fbt_collection: settings.cart_drawer_collection %}
{%- endcomment -%}

{%- if fbt_collection != blank and fbt_collection.products_count > 0 -%}
  {%- assign cart_ids = ',' -%}
  {%- for item in cart.items -%}
    {%- assign cart_ids = cart_ids | append: item.product_id | append: ',' -%}
  {%- endfor -%}

  {%- assign limit = settings.cart_cross_sell_limit | default: 8 -%}
  {%- assign shown = 0 -%}

  <div class="cart-drawer__sidebar" data-cart-sidebar-fbt>
    <div class="cart-drawer__sidebar-heading">
      {{ settings.cart_cross_sell_title | default: 'Frequently bought together' }}
    </div>
    <div class="cart-drawer__sidebar-list">
      {%- for product in fbt_collection.products -%}
        {%- if shown >= limit -%}
          {%- break -%}
        {%- endif -%}
        {%- assign needle = ',' | append: product.id | append: ',' -%}
        {%- unless cart_ids contains needle -%}
          {%- assign shown = shown | plus: 1 -%}
          {%- assign v = product.selected_or_first_available_variant -%}
          <div class="cart-fbt-item">
            <a href="{{ product.url }}" class="cart-fbt-item__media" aria-label="{{ product.title | escape }}">
              {%- if product.featured_media -%}
                {{
                  product.featured_media
                  | image_url: width: 240
                  | image_tag: widths: '160,240', loading: 'lazy', class: 'cart-fbt-item__img', alt: product.featured_media.alt | escape
                }}
              {%- else -%}
                <div class="cart-fbt-item__img cart-fbt-item__img--placeholder"></div>
              {%- endif -%}
            </a>

            <a href="{{ product.url }}" class="cart-fbt-item__title">{{ product.title }}</a>

            <div class="cart-fbt-item__price">
              {%- if product.price_varies -%}
                {{ product.price_min | money }} &ndash; {{ product.price_max | money }}
              {%- else -%}
                {{ v.price | money }}
              {%- endif -%}
            </div>

            {%- if product.has_only_default_variant and v.available -%}
              {%- assign formid = 'fbt-' | append: v.id -%}
              <product-form data-section-id="{{ v.id }}">
                {%- form 'product', product, id: formid, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                  {%- unless settings.disable_autogenerated_payment_terms -%}
                    {{ form | payment_terms }}
                  {%- endunless -%}
                  <input type="hidden" name="id" value="{{ v.id }}">
                  <button type="submit" name="add" class="cart-fbt-item__button button button--secondary">
                    {{ 'products.product.add_to_cart' | t | default: 'Add' }}
                  </button>
                {%- endform -%}
              </product-form>
            {%- else -%}
              <a href="{{ product.url }}" class="cart-fbt-item__button button button--secondary">
                {%- if v.available == false -%}
                  {{ 'products.product.sold_out' | t | default: 'Sold out' }}
                {%- else -%}
                  {{ 'products.product.choose_options' | t | default: 'Select options' }}
                {%- endif -%}
              </a>
            {%- endif -%}
          </div>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<style>
  .cart-drawer__sidebar {
    width: 300px;
    flex-shrink: 0;
    height: 100%;
    overflow-y: auto;
    background: #eef1f5;
    padding: clamp(1.6rem, 1.5vw, 2.4rem) 1.6rem;
    box-sizing: border-box;
  }

  .cart-drawer__sidebar-heading {
    font-family: var(--font-heading-family);
    font-size: 1.9rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.25;
    margin-bottom: 2.4rem;
  }

  .cart-drawer__sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 2.8rem;
  }

  .cart-fbt-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.6rem;
  }

  .cart-fbt-item__media {
    display: block;
    width: 116px;
    height: 116px;
    border-radius: 0.8rem;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  }

  .cart-fbt-item__img,
  .cart-fbt-item__img--placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-fbt-item__title {
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    line-height: 1.3;
  }

  .cart-fbt-item__price {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.75);
  }

  .cart-fbt-item__button {
    width: 100%;
    margin-top: 0.4rem;
    min-height: unset;
    padding: 1rem 1.2rem;
    font-size: 1.3rem;
    border-radius: 999px;
    background: transparent;
    color: var(--color-extra);
    border: 1px solid var(--color-extra);
  }

  .cart-fbt-item__button:hover {
    background: var(--color-extra);
    color: var(--gradient-background);
  }

  @media screen and (max-width: 899px) {
    .cart-drawer__sidebar {
      display: none;
    }
  }
</style>
