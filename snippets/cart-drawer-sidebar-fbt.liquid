{%- comment -%}
  Renders the vertical "Frequently bought together" sidebar for the two-column cart drawer.
  Uses card-product's quick_add: 'standard' so Add/Choose-options behaves exactly like the
  rest of the theme's quick-add: AJAX add-to-cart (or a variant-picker modal for products with
  options), then the cart drawer refreshes and stays open — no navigating away to the PDP.

  Usage:
  {% render 'cart-drawer-sidebar-fbt', fbt_collection: settings.cart_drawer_collection %}
{%- endcomment -%}

{%- if fbt_collection != blank and fbt_collection.products_count > 0 -%}
  {%- assign cart_ids = ',' -%}
  {%- for item in cart.items -%}
    {%- assign cart_ids = cart_ids | append: item.product_id | append: ',' -%}
  {%- endfor -%}

  {%- assign limit = settings.cart_cross_sell_limit | default: 8 -%}
  {%- assign shown = 0 -%}

  <div class="cart-drawer__sidebar" data-cart-sidebar-fbt>
    <div class="cart-drawer__sidebar-heading">
      {{ settings.cart_cross_sell_title | default: 'Frequently bought together' }}
    </div>
    <div class="cart-drawer__sidebar-list">
      {%- for product in fbt_collection.products -%}
        {%- if shown >= limit -%}
          {%- break -%}
        {%- endif -%}
        {%- assign needle = ',' | append: product.id | append: ',' -%}
        {%- unless cart_ids contains needle -%}
          {%- assign shown = shown | plus: 1 -%}
          <div class="cart-fbt-item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'square',
              show_secondary_image: false,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              quick_add: 'standard',
              section_id: 'cart-sidebar-fbt',
              skip_styles: shown > 1
            %}
          </div>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<style>
  .cart-drawer__sidebar {
    width: 300px;
    flex-shrink: 0;
    height: 100%;
    overflow-y: auto;
    background: linear-gradient(180deg, #f3ede1 0%, #ece3d2 100%);
    padding: clamp(1.8rem, 1.6vw, 2.6rem) 1.8rem;
    box-sizing: border-box;
    border-right: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .cart-drawer__sidebar-heading {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    line-height: 1.25;
    margin-bottom: 2.6rem;
    color: rgb(var(--color-foreground));
  }

  .cart-drawer__sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .cart-fbt-item {
    background: #fff;
    border-radius: 1.4rem;
    padding: 1.6rem 1.4rem 1.8rem;
    box-shadow: 0 1px 6px rgba(61, 31, 16, 0.08);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .cart-fbt-item:hover {
    box-shadow: 0 6px 16px rgba(61, 31, 16, 0.14);
    transform: translateY(-2px);
  }

  .cart-fbt-item .card-wrapper,
  .cart-fbt-item .card {
    text-align: center;
  }

  .cart-fbt-item .card__inner {
    max-width: 118px;
    margin: 0 auto 1.2rem;
    border-radius: 1rem;
    overflow: hidden;
  }

  .cart-fbt-item .card__badge,
  .cart-fbt-item .low-stock-indicator,
  .cart-fbt-item .card-attribute,
  .cart-fbt-item .rating,
  .cart-fbt-item .basmil-rating {
    display: none !important;
  }

  .cart-fbt-item .card__information {
    padding: 0;
  }

  .cart-fbt-item .card__heading {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 0.6rem;
  }

  .cart-fbt-item .card__heading a {
    color: rgb(var(--color-foreground));
  }

  .cart-fbt-item .price {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.75);
    justify-content: center;
  }

  .cart-fbt-item .price .price-item--regular {
    font-weight: 600;
    color: var(--color-extra);
  }

  .cart-fbt-item .quick-add {
    margin-top: 1.2rem;
  }

  .cart-fbt-item .quick-add__submit {
    width: 100%;
    min-height: unset;
    padding: 1rem 1.2rem;
    font-size: 1.3rem;
    font-weight: 600;
    border-radius: 999px;
    background: transparent !important;
    color: var(--color-extra) !important;
    border: 1px solid var(--color-extra) !important;
    box-shadow: none !important;
  }

  .cart-fbt-item .quick-add__submit:hover {
    background: var(--color-extra) !important;
    color: var(--gradient-background) !important;
  }

  @media screen and (max-width: 899px) {
    .cart-drawer__sidebar {
      display: none;
    }
  }
</style>
