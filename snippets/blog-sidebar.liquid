{%- liquid
  assign cheat = cheat_sheet | default: article.metafields.custom.cheat_sheet
  assign heading = heading | default: 'Cheat Sheet'
-%}

{%- if cheat == blank -%}
  {%- comment -%}No cheat sheet metafield set.{%- endcomment -%}
{%- else -%}
  <aside class="cheat-sheet" aria-label="{{ heading | escape }}">
    <div class="cheat-sheet__head">
      <div class="h3 cheat-sheet__title">{{ heading | escape }}</div>
    </div>

    <div class="cheat-sheet__body rte">
      {%- capture mf_render -%}{{ cheat | metafield_tag }}{%- endcapture -%}
      {%- if mf_render != blank -%}
        {{ mf_render }}
      {%- else -%}
        {{ cheat.value | default: cheat | escape | newline_to_br }}
      {%- endif -%}

      <hr>
       {%- liquid
          assign expert_heading = article.metafields.custom.expert.value.name | default: 'Meet our Expert'
          assign expert_content = article.metafields.custom.expert.value.detail
          assign expert_image = article.metafields.custom.expert.value.image
          assign show_expert = false
          if expert_content != blank or expert_image != blank
            assign show_expert = true
          endif
        -%}

        {%- if show_expert -%}
          <section class="article-expert" aria-label="{{ expert_heading | escape }}">

            <h2 class="h4">Author</h2>

            <div class="article-expert__grid">
              <div class="article-expert__text rte">
                {%- if expert_content != blank -%}
 Deepa Pudasaini
                {%- endif -%}
              </div>

              {%- if expert_image != blank -%}
                {%- liquid
                  assign img = expert_image.value
                  if img == blank
                    assign img = expert_image
                  endif
                  assign sizes = '(min-width: 190px) 220px, 40vw'
                  assign widths = '220, 320, 420, 540, 720'
                  assign h = img.width | divided_by: img.aspect_ratio | round
                -%}
                <div class="article-expert__media">
                  {{
                    img
                    | image_url: width: 80
                    | image_tag:
                      class: 'article-expert__img',
                      loading: 'lazy',
                      decoding: 'async',
                      sizes: sizes,
                      widths: widths,
                      height: h,
                      draggable: 'false'
                  }}
                </div>
              {%- endif -%}
            </div>
          </section>
        {%- endif -%}
    </div>
  </aside>
{%- endif -%}

{% comment %}
  {% style %}
      #shopify-section-{{ section.id }} {
        .field:after,.field:before {
          content: none;
        }
    }
  {% endstyle %}

  {%- assign custom_array = section.settings.categories | split: ',' -%}
  {% assign tagToSkip = articleTags | split: ',' %}
  <div class="sidebar top-[13rem] max-h-max sticky md:static sm:static max-w-[32.3%] md:max-w-full sm:max-w-full sm:mt-[2rem]">
    <div
      class="relative mobile-hide"
    >
      <form action="{{routes.search}}" method="get" role="search" class="search search-modal__form">
        <div class="field">
          <button
            class="search__button field__button"
            aria-label="Search"
          >
            <svg width="16" height="15" viewBox="0 0 16 15" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7.22209 12.9444C10.6585 12.9444 13.4442 10.1587 13.4442 6.72233C13.4442 3.28597 10.6585 0.500244 7.22209 0.500244C3.78572 0.500244 1 3.28597 1 6.72233C1 10.1587 3.78572 12.9444 7.22209 12.9444Z" stroke="#999999" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.0004 14.4997L11.6172 11.1165" stroke="#999999" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <input
            style="border:none; box-shadow: none!important; outline: none!important; "
            class="search__input bg-transparent w-full"
            id="Search-In-Modal"
            type="search"
            name="q"
            value=""
            placeholder="Search for blogs"
            role="combobox"
            aria-expanded="false"
            aria-owns="predictive-search-results"
            aria-controls="predictive-search-results"
            aria-haspopup="listbox"
            aria-autocomplete="list"
            autocorrect="off"
            autocomplete="off"
            autocapitalize="off"
            spellcheck="false"
          >
          {% comment %} <label class="field__label" for="Search-In-Modal">Search</label> {% endcomment %}
          <input type="hidden" name="options[prefix]" value="last">
          <button type="reset" class="hidden reset__button field__button" aria-label="Clear search term">
            <svg class="icon icon-close" aria-hidden="true" focusable="false">
                <use xlink:href="#icon-reset">
              </use>
            </svg>
          </button>
        </div>
      </form>
    </div>

    <hr class="mobile-hide" style="margin-top:12px">

    {% if settings.show_tags and request.page_type == 'blog' %}
      <div class="widget-wrapper">
        <h3 class="font-sans font-medium">{{ settings.tags_title }}</h3>
        <div class=" tags font-sans">
          {% assign tagblogs = settings.skip_tags.handle | append: ',' | append: settings.skip_tags2.handle %}
          {%- for category in custom_array -%}
            {% if tagblogs contains category %}
            {% else %}
              {%- for tag in blogs[category].all_tags -%}
                {% assign showtag = true %}
                {% for skipTag in tagToSkip %}
                  {% if tag == skipTag %}
                    {% assign showtag = false %}
                  {% endif %}
                {% endfor %}
                {% if showtag %}
                  <a
                    href="{{ blog.url | append: '/tagged/' | append: tag.handle }}"
                  >
                    {{- tag -}}
                  </a>
                {% endif %}
              {%- endfor -%}
            {% endif %}
          {%- endfor -%}
        </div>
      </div>
      <hr>
    {% endif %}

    {% if settings.show_tags and request.page_type == 'article' %}
      {% unless request.path contains '/blogs/press-media' %}
        <div class="toc-table">
          <div>
            <h3 class="font-sans font-medium">Table of Content</h3>
            <hr>
          </div>
          <ul id="toc" class=" list-none ml-[1.5em]  flex flex-col gap-[.8rem] font-sans "></ul>
        </div>
      {% endunless %}
    {% endif %}

    {% if settings.recent_posts_blog %}
      <div class="widget-wrapper">
        <h3 class="font-sans  font-medium">{{ settings.recent_posts_title }}</h3>
        {%- assign recent_posts_blog = settings.recent_posts_blog -%}
        {%- for article in recent_posts_blog.articles limit: 3 -%}
          {%- render 'article-card',
            article: article,
            media_height: settings.image_height,
            media_aspect_ratio: article.image.aspect_ratio,
            show_image: settings.show_image,
            show_date: settings.show_date,
            show_author: settings.show_author,
            show_excerpt: false,
            style: 'horizontal'
          -%}
        {%- endfor -%}
      </div>
      <hr>
    {% endif %}

    {% if settings.most_read_blog != blank %}
      <div class="widget-wrapper most-read-article">
        <h3 class="font-sans  font-medium mb-[24px]">Most Read Article</h3>
        {%- assign most_read_blog = blogs[settings.most_read_blog] -%}
        {%- if most_read_blog and most_read_blog.articles.size > 0 -%}
          <div class="widget-wrapper">
            {%- assign articles_shown = 0 -%}
            {%- for article in most_read_blog.articles limit: 99999 -%}
              {%- assign most_view = article.metafields.custom.most_view | default: 0 | plus: 0 -%}
              {%- if most_view == 3 or most_view == 2 or most_view == 1 -%}
                {%- if articles_shown < 3 -%}
                  <div class="{%- if most_view == 1 -%}order-1 {%- elsif most_view == 2 -%}order-2 {%- elsif most_view == 3 -%}order-3 {%- endif -%}">
                    {%- render 'article-card',
                      article: article,
                      media_height: settings.image_height,
                      media_aspect_ratio: article.image.aspect_ratio,
                      show_image: settings.show_image,
                      show_date: settings.show_date,
                      show_author: settings.show_author,
                      show_excerpt: false,
                      style: 'horizontal'
                    -%}

                    {%- assign articles_shown = articles_shown | plus: 1 -%}
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {% endif %}
  </div>
{% endcomment %}
