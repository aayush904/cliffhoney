{% assign progress_bar_color = settings.shipping_bar_color %}

<div class="basmil upsell-container ">
  {% assign shipping_value = settings.minimum_free_shipping | times: 100 %}
  {% assign cart_total = cart.total_price %}
  {% assign shipping_value_left = shipping_value | minus: cart_total %}
  {% assign shipping_percentage_fraction = cart_total | times: 100 | divided_by: shipping_value %}
  <p class="shipping-message">
    {% if shipping_value_left > 0 %}
      <span class="free_shipping_notice"
        >You’re
        <span style="color:#981515">{{ shipping_value_left | money }}</span>
        away from free shipping!</span
      >
    {% elsif shipping_value_left <= 0 %}
      <span>You have free shipping !!!</span>
    {% endif %}
  </p>

  <div class="progress-bar">
    <div class="transition-all progress-bar-done" data-progress="loading">
      <span></span>
    </div>
    <div
      class="progress-dot"
      style="
        display:block!important;
        left: {% if shipping_percentage_fraction >= 100 %}
          100%
          {% else %}
          {{ shipping_percentage_fraction }}%
          {% endif %};
      "
    ></div>
  </div>
</div>

<style>
    .upsell-container {
      display: flex;
      flex-direction: column;
      margin-bottom: 2rem;
      display: flex;
    justify-content: center;
    align-items: center;
    }

    .shipping-message{
        margin-top:0;
        font-size: 14px;
        margin-bottom: 8px;
        text-align: center;
        font-weight:600;
    }

    .progress-bar {
      display: flex;
      height: 8px;
      width: 100%;
      position: relative;
      align-items: center;
      box-shadow: -1px 0px 2px 0px #00000040;
      border: 1px solid #3B170066;
  }

    .progress-bar-done {
      display: flex;
      text-align: center;
      align-items: center;
      justify-content: center;
      background-color: {{ progress_bar_color }};
      box-shadow: 0 5px 5px -6px{{ progress_bar_color }};
      z-index: 2;
      margin-left:-1px;
      height: calc(100% + 2px);
      transition: 1s ease 0.3s;
      max-width: 100%;
      width: calc({{ shipping_percentage_fraction }}% + 2px);
    }

    .progress-dot{
      position: absolute;
      border-radius: 9999px;
      transition-property: all;
      transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      transition-duration: 300ms;
      top: 50%;
      height: 12px;
      background: var(--color-extra);
      box-shadow: -1px 0px 2px 0px #00000040;
      width: 12px;
      transform: translate(-80%, -50%);
      z-index: 3;
    }

    .free-shipping-icon {
      position: absolute;
      right: 0;
      width: 40px;
      height: 40px;
      border-radius: 20px;
      background-color: #E2E4E3;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    {% comment %}
     .progress-bar::before {
      content: ' ';
      width: calc(100% - 6px);
      position: absolute;
      border: 1px solid #D9D9D9;
      height: calc(100% - 8px);
      z-index: 0;
    }
    {% endcomment %}

    .iconicion {
      box-shadow: 0 0 10px rgba(62, 101, 207, 0.5);
      border: 1px solid black;
      transition: 1s ease 0.7s;
    }
</style>
